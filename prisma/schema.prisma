generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  GOOGLE_ADS
  GA4
  SEARCH_CONSOLE
  GMAIL
  META
  TIKTOK
}

enum ConnectionStatus {
  CONNECTED
  ERROR
  EXPIRED
  DISCONNECTED
  PENDING
}

enum SyncJobType {
  DISCOVER
  TEST
  MANUAL_SYNC
  REFRESH
  SYNC_ACCOUNTS
  SYNC_CAMPAIGNS
  SYNC_METRICS
  SNAPSHOT_DAILY
  REFRESH_TOKENS
  ACTION
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum ConnectedAccountStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum OAuthStateStatus {
  ISSUED
  CONSUMED
  EXPIRED
}

enum ActionRequestStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  image               String?
  role                String               @default("user")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  platformConnections PlatformConnection[]
  connectedAccounts   ConnectedAccount[]
  syncJobs            SyncJob[]
  auditLogs           AuditLog[]
  oauthStates         OAuthState[]
  unifiedCampaigns    UnifiedCampaign[]
  unifiedCampaignMetricDaily UnifiedCampaignMetricDaily[]
  unifiedCampaignMetricHourly UnifiedCampaignMetricHourly[]
  unifiedSnapshotsDaily UnifiedSnapshotDaily[]
  syncErrorLogs       SyncErrorLog[]
  actionRequests               ActionRequest[]
  oneClickCampaignRequests     OneClickCampaignRequest[]

  @@index([createdAt])
  @@index([updatedAt])
}

model PlatformConnection {
  id                    String             @id @default(cuid())
  userId                String
  platform              Platform
  status                ConnectionStatus   @default(PENDING)
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  scopes                Json?
  tokenType             String?
  externalUserId        String?
  externalBusinessId    String?
  metadata              Json?
  lastSyncAt            DateTime?
  lastError             String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccounts     ConnectedAccount[]
  syncJobs              SyncJob[]
  auditLogs             AuditLog[]
  unifiedCampaigns      UnifiedCampaign[]
  actionRequests        ActionRequest[]

  @@unique([userId, platform])
  @@index([userId, platform, status])
  @@index([status, updatedAt])
  @@index([updatedAt])
}

model ConnectedAccount {
  id                   String                 @id @default(cuid())
  userId               String
  platformConnectionId String
  platform             Platform
  externalAccountId    String
  externalParentId     String?
  name                 String
  currency             String?
  timezone             String?
  status               ConnectedAccountStatus @default(ACTIVE)
  isSelected           Boolean                @default(false)
  metadata             Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConnection   PlatformConnection     @relation(fields: [platformConnectionId], references: [id], onDelete: Cascade)
  unifiedCampaigns     UnifiedCampaign[]
  actionRequests       ActionRequest[]

  @@unique([platformConnectionId, externalAccountId])
  @@index([userId, platform])
  @@index([platformConnectionId, isSelected])
  @@index([updatedAt])
}

model SyncJob {
  id           String       @id @default(cuid())
  userId       String
  platform     Platform
  connectionId String
  type         SyncJobType
  status       SyncJobStatus @default(QUEUED)
  requestedBy  String
  bullmqJobId  String?       @unique
  payload      Json?
  priority     Int?
  scheduledFor DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  runs         SyncRun[]

  @@index([userId, platform, status])
  @@index([connectionId, createdAt])
  @@index([updatedAt])
}

model SyncRun {
  id            String        @id @default(cuid())
  syncJobId     String
  status        SyncJobStatus
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  errorMessage  String?
  resultSummary Json?
  syncJob       SyncJob       @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId, startedAt])
}

model AuditLog {
  id           String              @id @default(cuid())
  userId       String
  action       String
  platform     Platform?
  connectionId String?
  details      Json?
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   PlatformConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([platform, createdAt])
  @@index([action, createdAt])
}

model OAuthState {
  id              String           @id @default(cuid())
  userId          String
  platform        Platform
  stateHash       String           @unique
  codeVerifierEnc String
  redirectPath    String?
  status          OAuthStateStatus @default(ISSUED)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, status])
  @@index([expiresAt])
}

model UnifiedCampaign {
  id                 String              @id @default(cuid())
  userId             String
  platform           Platform
  connectionId       String
  connectedAccountId String
  externalCampaignId String
  name               String
  status             String
  objective          String?
  currency           String?
  timezone           String?
  raw                Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection         PlatformConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  account            ConnectedAccount    @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  metricsDaily       UnifiedCampaignMetricDaily[]
  metricsHourly      UnifiedCampaignMetricHourly[]

  @@unique([platform, connectedAccountId, externalCampaignId])
  @@index([userId, platform])
  @@index([connectionId, updatedAt])
}

model UnifiedCampaignMetricDaily {
  id                String          @id @default(cuid())
  userId            String
  unifiedCampaignId String
  date              DateTime
  impressions       Int             @default(0)
  clicks            Int             @default(0)
  spend             Decimal         @default(0)
  conversions       Decimal         @default(0)
  revenue           Decimal?
  raw               Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign          UnifiedCampaign @relation(fields: [unifiedCampaignId], references: [id], onDelete: Cascade)

  @@unique([unifiedCampaignId, date])
  @@index([userId, date])
}

model UnifiedCampaignMetricHourly {
  id                String          @id @default(cuid())
  userId            String
  unifiedCampaignId String
  hour              DateTime
  impressions       Int             @default(0)
  clicks            Int             @default(0)
  spend             Decimal         @default(0)
  conversions       Decimal         @default(0)
  revenue           Decimal?
  raw               Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign          UnifiedCampaign @relation(fields: [unifiedCampaignId], references: [id], onDelete: Cascade)

  @@unique([unifiedCampaignId, hour])
  @@index([userId, hour])
}

model UnifiedSnapshotDaily {
  id               String    @id @default(cuid())
  userId           String
  date             DateTime
  totalSpend       Decimal   @default(0)
  totalRevenue     Decimal?
  totalConversions Decimal   @default(0)
  totalClicks      Int       @default(0)
  totalImpressions Int       @default(0)
  raw              Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model SyncErrorLog {
  id           String    @id @default(cuid())
  userId       String
  platform     Platform?
  connectionId String?
  syncJobId    String?
  syncRunId    String?
  category     String
  message      String
  details      Json?
  occurredAt   DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([platform, occurredAt])
  @@index([connectionId, occurredAt])
}

model ActionRequest {
  id               String              @id @default(cuid())
  userId           String
  platform         Platform
  connectionId     String
  connectedAccountId String
  actionType       String
  targetType       String
  targetExternalId String
  payload          Json
  status           ActionRequestStatus @default(QUEUED)
  errorMessage     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection       PlatformConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  account          ConnectedAccount    @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([userId, platform, createdAt])
}

// ─── One Click Campaign ──────────────────────────────────────────────────────
// Stores every one-click campaign request for idempotency, audit, and retry.
model OneClickCampaignRequest {
  id              String   @id @default(cuid())
  userId          String
  // SHA-256(userId + canonicalised inputs) prevents duplicate launches.
  idempotencyKey  String   @unique
  platforms       Json     // string[] — e.g. ["Google","Meta"]
  objective       String   // "sales" | "leads" | "traffic"
  dailyBudget     Float
  country         String
  language        String
  productInfo     Json?    // { name, description, price, url }
  aiStrategy      Json?    // OneClickStrategy — stored after generation
  // "PENDING" | "RUNNING" | "SUCCESS" | "PARTIAL" | "FAILED"
  status          String   @default("PENDING")
  results         Json?    // Partial<Record<Platform, PlatformResult>>
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([idempotencyKey])
}
