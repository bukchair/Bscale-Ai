{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "strictNullChecks": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/components/connections/**/*.ts",
    "src/components/connections/**/*.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/pages/**",
    "src/lib/firebase.ts",
    "src/lib/autoAdsRunner.ts",
    "src/lib/unified-data/**",
    "src/lib/dataUtils.ts",
    "src/lib/gemini.ts",
    "src/contexts/**",
    "src/services/**"
  ]
}
