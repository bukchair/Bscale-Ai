{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/automations/layout,_N_T_/(app)/automations/page,_N_T_/automations"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/automations/__PAGE__",
    "/!KGFwcCk/automations",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}