generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  GOOGLE_ADS
  GA4
  SEARCH_CONSOLE
  GMAIL
  META
  TIKTOK
}

enum ConnectionStatus {
  CONNECTED
  ERROR
  EXPIRED
  DISCONNECTED
  PENDING
}

enum SyncJobType {
  DISCOVER
  TEST
  MANUAL_SYNC
  REFRESH
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum ConnectedAccountStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum OAuthStateStatus {
  ISSUED
  CONSUMED
  EXPIRED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  platformConnections PlatformConnection[]
  connectedAccounts   ConnectedAccount[]
  syncJobs            SyncJob[]
  auditLogs           AuditLog[]
  oauthStates         OAuthState[]

  @@index([createdAt])
  @@index([updatedAt])
}

model PlatformConnection {
  id                    String             @id @default(cuid())
  userId                String
  platform              Platform
  status                ConnectionStatus   @default(PENDING)
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  scopes                Json?
  tokenType             String?
  externalUserId        String?
  externalBusinessId    String?
  metadata              Json?
  lastSyncAt            DateTime?
  lastError             String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccounts     ConnectedAccount[]
  syncJobs              SyncJob[]
  auditLogs             AuditLog[]

  @@unique([userId, platform])
  @@index([userId, platform, status])
  @@index([status, updatedAt])
  @@index([updatedAt])
}

model ConnectedAccount {
  id                   String                 @id @default(cuid())
  userId               String
  platformConnectionId String
  platform             Platform
  externalAccountId    String
  externalParentId     String?
  name                 String
  currency             String?
  timezone             String?
  status               ConnectedAccountStatus @default(ACTIVE)
  isSelected           Boolean                @default(false)
  metadata             Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConnection   PlatformConnection     @relation(fields: [platformConnectionId], references: [id], onDelete: Cascade)

  @@unique([platformConnectionId, externalAccountId])
  @@index([userId, platform])
  @@index([platformConnectionId, isSelected])
  @@index([updatedAt])
}

model SyncJob {
  id           String       @id @default(cuid())
  userId       String
  platform     Platform
  connectionId String
  type         SyncJobType
  status       SyncJobStatus @default(QUEUED)
  requestedBy  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  runs         SyncRun[]

  @@index([userId, platform, status])
  @@index([connectionId, createdAt])
  @@index([updatedAt])
}

model SyncRun {
  id            String        @id @default(cuid())
  syncJobId     String
  status        SyncJobStatus
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  errorMessage  String?
  resultSummary Json?
  syncJob       SyncJob       @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId, startedAt])
}

model AuditLog {
  id           String              @id @default(cuid())
  userId       String
  action       String
  platform     Platform?
  connectionId String?
  details      Json?
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection   PlatformConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([platform, createdAt])
  @@index([action, createdAt])
}

model OAuthState {
  id              String           @id @default(cuid())
  userId          String
  platform        Platform
  stateHash       String           @unique
  codeVerifierEnc String
  redirectPath    String?
  status          OAuthStateStatus @default(ISSUED)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, status])
  @@index([expiresAt])
}
