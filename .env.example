# =========================================================
# Existing app variables
# =========================================================
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
VITE_GTM_ID=

# =========================================================
# Connections Center / Integrations module (Next.js + Prisma)
# =========================================================
# TODO: Set your PostgreSQL connection string.
DATABASE_URL=

# TODO: Set your app base URL (without trailing slash).
# Example: https://app.yourdomain.com
APP_BASE_URL=

# TODO: Set a strong random secret for session JWT verification.
# Recommended: 32+ chars.
SESSION_SIGNING_SECRET=

# TODO: Set a secure random 32-byte key in base64 for AES-256-GCM encryption.
# Generate example:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Optional: Previous encryption keys (comma-separated base64 keys) for key rotation reads.
ENCRYPTION_KEY_PREVIOUS=

# Optional feature flags
ENABLE_GMAIL_SEND_SCOPE=false
TIKTOK_REPORTING_ENABLED=false
OAUTH_STATE_TTL_SECONDS=600

# =========================================================
# Google OAuth (used by Google Ads / GA4 / Search Console / Gmail)
# =========================================================
# TODO: Create OAuth Web app credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# TODO: Required for Google Ads API requests.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional manager customer id for manager-level API calls.
GOOGLE_ADS_MANAGER_CUSTOMER_ID=

# =========================================================
# Meta Marketing API
# =========================================================
# TODO: Create app in Meta for Developers.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# =========================================================
# TikTok for Business
# =========================================================
# TODO: Create TikTok developer app + business approval.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# =========================================================
# Sync Engine (Queue + Worker + Cache)
# =========================================================
# Preferred single URL
REDIS_URL=
# Optional split values
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=false

# Cron route guard
CRON_SECRET=

# Worker metadata / tuning
WORKER_INSTANCE_ID=local-dev
SYNC_METRICS_DEFAULT_LOOKBACK_DAYS=30
SYNC_HOURLY_LOOKBACK_HOURS=48
TIKTOK_SYNC_ENABLED=false

