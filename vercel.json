{
  "framework": "nextjs",
  "buildCommand": "npm run next:build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-all",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/snapshot-daily",
      "schedule": "5 0 * * *"
    }
  ]
}
