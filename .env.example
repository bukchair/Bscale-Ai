# === Core app configuration ===
# Production:
#   APP_URL="https://bscale.co.il"
# Local development:
#   APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === Meta (Facebook / Instagram Ads) ===
# Create an app in https://developers.facebook.com/
# and copy the App ID + App Secret.
META_APP_ID=""
META_APP_SECRET=""
# For production use your live domain; for local use http://localhost:3000
META_REDIRECT_URI="https://bscale.co.il/api/auth/meta/callback"

# === Google (service-split OAuth) ===
# OAuth 2.0 Client ID for Web in Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Legacy/shared Google OAuth callback (kept for backwards compatibility)
GOOGLE_REDIRECT_URI="https://bscale.co.il/api/auth/google/callback"

# Per-service OAuth callbacks (recommended)
GOOGLE_ADS_REDIRECT_URI="https://bscale.co.il/api/integrations/google-ads/callback"
GA4_REDIRECT_URI="https://bscale.co.il/api/integrations/ga4/callback"
SEARCH_CONSOLE_REDIRECT_URI="https://bscale.co.il/api/integrations/search-console/callback"
GMAIL_REDIRECT_URI="https://bscale.co.il/api/integrations/gmail/callback"

# Google Ads API developer token (required for Ads routes/discovery)
GOOGLE_ADS_DEVELOPER_TOKEN=""

# Local path for managed Google integration token DB
GOOGLE_INTEGRATIONS_DB_PATH=".data/google-integrations.db"

# === TikTok Ads ===
# Create app in https://business-api.tiktok.com/
TIKTOK_APP_ID=""
TIKTOK_SECRET=""
TIKTOK_REDIRECT_URI="https://bscale.co.il/api/auth/tiktok/callback"

# === Sync / Worker ===
# Redis (required for BullMQ job queues)
# Use REDIS_URL for services that provide a single connection string (e.g. Upstash):
#   REDIS_URL="rediss://default:<password>@<host>:<port>"
# Or set individual host/port/password for self-hosted Redis:
REDIS_URL=""
REDIS_HOST=""
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_TLS="false"

# Secret used to authenticate Vercel Cron requests to /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Optional: tag for worker process logs (helpful when running multiple workers)
WORKER_INSTANCE_ID="local-worker"

# How many days back to pull metrics on each hourly sync run (default: 30)
SYNC_METRICS_DEFAULT_LOOKBACK_DAYS="30"

# Set to "true" to enable TikTok metrics sync (disabled by default)
TIKTOK_SYNC_ENABLED="false"
